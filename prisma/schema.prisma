generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String?  @unique
  name          String
  password      String
  phone         String?
  role          String   @default("user") // "user" or "admin"
  avatar        String?
  country       String?
  languagePreference String @default("bn") // "bn" or "en"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Reputation fields
  buyerRating        Float    @default(0)
  sellerRating       Float    @default(0)
  totalReviews       Int      @default(0)
  completedDeals     Int      @default(0)
  successfulTransactions Int @default(0)
  trustScore         Float    @default(0)
  disputeRate        Float    @default(0)
  isVerified         Boolean  @default(false)

  // Account type & activity
  accountType         String   @default("both") // "buyer", "seller", "both"
  lastActive          DateTime @default(now())

  // Subscription
  currentSubscriptionId String?

  buyerTransactions    Transaction[] @relation("BuyerTransactions")
  sellerTransactions   Transaction[] @relation("SellerTransactions")
  sentNotifications    Notification[] @relation("NotificationRecipient")
  payments             Payment[]
  buyerDisputes        Dispute[] @relation("BuyerDisputes")
  sellerDisputes       Dispute[] @relation("SellerDisputes")
  disputeMessages      DisputeMessage[]
  adminLogs            AdminLog[]
  gatewayTransactions  GatewayTransaction[]
  subscriptions        UserSubscription[]
  receivedReviews      Review[] @relation("ReviewRecipient")
  givenReviews         Review[] @relation("ReviewAuthor")
  reports              Report[] @relation("ReportedUser")
  reportsFiled         Report[] @relation("ReportAuthor")
}

model Transaction {
  id              String   @id @default(cuid())
  title           String
  description     String
  amount          Float
  terms           String
  status          String   @default("pending_payment") // pending_payment, pending_verification, paid, work_in_progress, delivered, completed, disputed, cancelled
  buyerId         String
  sellerId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  buyer           User     @relation("BuyerTransactions", fields: [buyerId], references: [id])
  seller          User     @relation("SellerTransactions", fields: [sellerId], references: [id])
  payments        Payment[]
  disputes        Dispute[]
  notifications   Notification[]
  gatewayTransactions GatewayTransaction[]
  reviews             Review[]
}

model Payment {
  id              String   @id @default(cuid())
  transactionId   String
  userId          String
  transactionRef  String   // Transaction ID from payment
  paymentMethod   String   // bKash, Nagad, Rocket, Bank Transfer
  screenshot      String?  // base64 or file path
  status          String   @default("pending") // pending, approved, rejected
  adminNote       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transaction     Transaction @relation(fields: [transactionId], references: [id])
  user            User @relation(fields: [userId], references: [id])
}

model Dispute {
  id              String   @id @default(cuid())
  transactionId   String
  buyerId         String
  sellerId        String
  reason          String
  status          String   @default("open") // open, under_review, resolved_buyer, resolved_seller, resolved_cancelled
  resolution      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transaction     Transaction @relation(fields: [transactionId], references: [id])
  buyer           User @relation("BuyerDisputes", fields: [buyerId], references: [id])
  seller          User @relation("SellerDisputes", fields: [sellerId], references: [id])
  messages        DisputeMessage[]
}

model DisputeMessage {
  id          String   @id @default(cuid())
  disputeId   String
  userId      String
  message     String
  createdAt   DateTime @default(now())

  dispute     Dispute  @relation(fields: [disputeId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Notification {
  id              String   @id @default(cuid())
  userId          String
  transactionId   String?
  title           String
  message         String
  type            String   // transaction, payment, dispute, system
  isRead          Boolean  @default(false)
  createdAt       DateTime @default(now())

  user            User @relation("NotificationRecipient", fields: [userId], references: [id])
  transaction     Transaction? @relation(fields: [transactionId], references: [id])
}

model AdminLog {
  id          String   @id @default(cuid())
  userId      String
  action      String
  details     String
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id])
}

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model PaymentGateway {
  id              String   @id @default(cuid())
  name            String                         // e.g. "bKash Personal", "Nagad", "Bank Transfer"
  slug            String   @unique               // e.g. "bkash-personal", "nagad"
  logo            String?                        // URL or base64 of gateway logo
  accountType     String                         // e.g. "personal", "merchant", "bank"
  accountNumber   String                         // The number users send money to
  accountName     String                         // Name on the account
  instructions    String?                        // Payment instructions for users
  minDeposit      Float    @default(0)           // Minimum deposit amount
  maxDeposit      Float    @default(999999)      // Maximum deposit amount
  isActive        Boolean  @default(true)        // ON/OFF toggle
  sortOrder       Int      @default(0)           // Display order (lower = first)

  // Per-gateway theme colors
  themeEnabled    Boolean  @default(true)        // Enable custom theme for this gateway
  primaryColor    String   @default("#6BBF59")   // Primary/accent color
  buttonColor     String   @default("#6BBF59")   // Submit button color
  borderColor     String   @default("#6BBF59")   // Border/accent color
  backgroundColor String   @default("#f0f7ee")   // Background highlight color

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  gatewayTransactions GatewayTransaction[]
}

model GatewayTransaction {
  id              String   @id @default(cuid())
  transactionId   String                         // The escrow transaction this payment is for
  gatewayId       String                         // Which payment gateway was used
  userId          String                         // Who submitted the payment
  transactionRef  String                         // Transaction ID / Reference from user
  amount          Float                          // Payment amount
  screenshot      String?                        // Payment screenshot (base64 or URL)
  note            String?                        // Optional user note
  status          String   @default("pending")   // pending, approved, rejected
  adminNote       String?                        // Admin's note on approval/rejection
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transaction     Transaction @relation(fields: [transactionId], references: [id])
  gateway         PaymentGateway @relation(fields: [gatewayId], references: [id])
  user            User @relation(fields: [userId], references: [id])
}

// ─── Subscription & Badge System ─────────────────────────

model SubscriptionPlan {
  id              String   @id @default(cuid())
  name            String                        // "Basic", "Premium", "Verified Pro", "Business", "Trusted Elite"
  slug            String   @unique              // "basic", "premium", "verified-pro", "business", "trusted-elite"
  description     String                        // Plan description
  badgeIcon       String                        // Icon identifier for the badge (e.g. 'star', 'diamond', 'crown')
  badgeColor      String   @default("#6BBF59")  // Badge accent color
  monthlyPrice    Float    @default(0)          // 0 = free
  yearlyPrice     Float    @default(0)          // 0 = free
  isActive        Boolean  @default(true)       // Admin can enable/disable
  sortOrder       Int      @default(0)          // Display order

  // Feature flags
  priorityListing       Boolean @default(false)
  premiumProfile        Boolean @default(false)
  featuredProfile       Boolean @default(false)
  higherDealLimits      Boolean @default(false)
  prioritySupport       Boolean @default(false)
  advancedAnalytics     Boolean @default(false)
  customProfileBanner   Boolean @default(false)
  featuredSellerStatus  Boolean @default(false)
  featuredBuyerStatus   Boolean @default(false)
  fasterDisputeResolution Boolean @default(false)
  profileVerification   Boolean @default(false)
  vipSupport            Boolean @default(false)
  maximumVisibility     Boolean @default(false)
  exclusiveFeatures     Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   UserSubscription[]
}

model UserSubscription {
  id              String   @id @default(cuid())
  userId          String
  planId          String
  status          String   @default("active")   // active, expired, cancelled, pending
  billingCycle    String   @default("monthly")  // monthly, yearly
  startDate       DateTime @default(now())
  endDate         DateTime?
  autoRenew       Boolean  @default(true)
  paymentMethod   String?
  transactionRef  String?                         // Payment reference
  cancelledAt     DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  plan            SubscriptionPlan  @relation(fields: [planId], references: [id])
}

// ─── Review & Report System ─────────────────────────

model Review {
  id              String   @id @default(cuid())
  fromUserId      String                        // Who wrote the review
  toUserId        String                        // Who received the review
  transactionId   String?                       // Optional: linked transaction
  rating          Int                            // 1-5 stars
  comment         String?                        // Review text
  reviewType      String   @default("general")  // "buyer", "seller", "general"
  isPublic        Boolean  @default(true)        // Show on public profile
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fromUser        User     @relation("ReviewAuthor", fields: [fromUserId], references: [id])
  toUser          User     @relation("ReviewRecipient", fields: [toUserId], references: [id])
  transaction     Transaction? @relation(fields: [transactionId], references: [id])
}

model Report {
  id              String   @id @default(cuid())
  reporterId      String                        // Who filed the report
  reportedUserId  String                        // Who is being reported
  reason          String                        // Report reason
  description     String?                       // Additional details
  status          String   @default("pending")  // pending, reviewed, dismissed, actioned
  adminNote       String?                       // Admin response
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reporter        User     @relation("ReportAuthor", fields: [reporterId], references: [id])
  reportedUser    User     @relation("ReportedUser", fields: [reportedUserId], references: [id])
}
